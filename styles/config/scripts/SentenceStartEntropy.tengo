text := import("text")
math := import("math")

matches := []

// Log base 2 via change-of-base: log2(x) = ln(x) / ln(2).
ln2 := math.log(2.0)

// Split document into sections by markdown headings.
// Measure sentence-start entropy within each section independently.
sections := text.re_split(`\n#{1,6}\s+[^\n]+\n`, scope)

for section in sections {
    section = text.trim_space(section)
    if section == "" {
        continue
    }

    // Strip fenced code blocks.
    clean := text.re_replace("(?s)```.*?```", section, "")

    // Filter out list items, table rows, and HTML comments line by line.
    lines := text.split(clean, "\n")
    prose_lines := []
    for line in lines {
        trimmed := text.trim_space(line)
        if text.has_prefix(trimmed, "- ") || text.has_prefix(trimmed, "* ") || text.has_prefix(trimmed, "1.") {
            continue
        }
        if text.has_prefix(trimmed, "- [") {
            continue
        }
        if text.has_prefix(trimmed, "|") {
            continue
        }
        if text.has_prefix(trimmed, "<!--") {
            continue
        }
        prose_lines = append(prose_lines, line)
    }
    clean = text.join(prose_lines, "\n")

    // Collapse whitespace for sentence splitting.
    flat := text.re_replace(`\n{2,}`, clean, " ")
    flat = text.re_replace(`\s+`, flat, " ")
    flat = text.trim_space(flat)

    if flat == "" {
        continue
    }

    // Split into sentences at terminal punctuation followed by whitespace.
    sentences := text.re_split(`[.!?]+\s+`, flat)

    // Count first words across sentences in this section.
    first_words := {}
    total := 0
    for s in sentences {
        trimmed := text.trim_space(s)
        if trimmed != "" {
            words := text.re_split(`\s+`, trimmed)
            if len(words) > 0 {
                word := text.to_lower(words[0])
                // Strip leading punctuation (quotes, parens, etc.).
                word = text.re_replace(`^[^a-z]+`, word, "")
                // Skip single-char words that naturally repeat.
                if len(word) >= 2 {
                    if first_words[word] == undefined {
                        first_words[word] = 0
                    }
                    first_words[word] += 1
                    total += 1
                }
            }
        }
    }

    // Need at least 8 sentences in this section for a meaningful measurement.
    if total >= 8 {
        // Count unique starting words.
        unique_count := 0
        for _, _ in first_words {
            unique_count += 1
        }

        // Shannon entropy is only meaningful with more than one unique word.
        if unique_count > 1 {
            // Compute Shannon entropy: H = -sum(p * log2(p)).
            entropy := 0.0
            for _, count in first_words {
                p := (0.0 + count) / total
                if p > 0 {
                    entropy = entropy - p * (math.log(p) / ln2)
                }
            }

            // Normalize by maximum possible entropy: H_max = log2(unique_count).
            h_max := math.log(0.0 + unique_count) / ln2
            h_norm := entropy / h_max

            // Flag when normalized entropy < 0.65 (low diversity).
            // A value of 1.0 means perfectly uniform distribution.
            // Below 0.65 means sentence starters cluster heavily.
            if h_norm < 0.65 {
                start := text.index(scope, section)
                if start < 0 {
                    start = 0
                }
                end := start + len(section)
                if end > len(scope) {
                    end = len(scope)
                }
                matches = append(matches, {begin: start, end: end})
            }
        }
    }
}
